# ============================================
VITE_RSVP_WHATSAPP_ENABLED=true
VITE_RSVP_WHATSAPP_NUMBER=543512280243
VITE_RSVP_WHATSAPP_MESSAGE=Hola! Confirmo mi asistencia a la boda de Novia & Novio.

# ============================================
