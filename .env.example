# ============================================
VITE_RSVP_EMAIL_ENABLED=true
VITE_RSVP_EMAIL_ADDRESS=invitacion@mail.com

# ============================================
# NUESTRA HISTORIA (OURSTORY)
# ============================================
VITE_OUR_STORY_TITLE=Nuestra Historia
VITE_OUR_STORY_CONTENT=Nos conocimos una tarde de primavera en el parque central de la ciudad. Desde el primer momento supimos que había algo especial entre nosotros. Después de cinco años de amor, risas y aventuras juntos, hemos decidido dar el siguiente paso y unir nuestras vidas para siempre. Queremos compartir este momento tan especial contigo, y nos encantaría que nos acompañes en el día más importante de nuestras vidas.
VITE_OUR_STORY_IMAGE=/images/1-pareja.jpg

# GALERÍA DE FOTOS (GALLERY)

# Opción 1 - Formato simple (separado por comas):
# Opción 2 - Formato JSON (con texto alternativo):
# VITE_GALLERY_IMAGES=[{"url":"/foto1.jpg","alt":"Foto de la pareja"},{"url":"/foto2.jpg","alt":"Foto del anillo"}]



VITE_GALLERY_IMAGES=/images/1-pareja.jpg,/images/2-pareja.jpg,/images/3-pareja.jpg,/images/4-pareja.jpg,/images/5-pareja.jpg,/images/6-pareja.jpg

