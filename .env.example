# ============================================
# BABY SHOWER — Max · Bosque encantado
# ============================================
# Copiá a `.env` y editá. Los valores por defecto están en `src/config/weddingConfig.ts`.
# Se mantienen nombres tipo VITE_CEREMONY_* por compatibilidad; podés usar los alias VITE_EVENT_*.

# ----- Bebé & familia -----
VITE_BRIDE_NAME=Max
VITE_GROOM_NAME=
VITE_COUPLE_NAMES=Max
VITE_BABY_NAME=Max
VITE_PARENTS_LINE=Esperando a Max 💚
VITE_PARENT_MOM_NAME=Yami
VITE_PARENT_DAD_NAME=Juan

# Hermana (opcional: nombre vacío muestra texto sin “Soy…”)
VITE_SISTER_SECTION_ENABLED=true
VITE_SISTER_NAME=Mia
# VITE_SISTER_IMAGE=/images/mia-abrazo-panza.png
# Para ocultar la foto del bloque de Mia: VITE_SISTER_IMAGE=none
# VITE_SISTER_IMAGE_CAPTION=Mia esperando a su hermanito Max 💚
# VITE_SISTER_OPENING_LINE=Hola 💚
VITE_SISTER_KICKER=Una luciérnaga más en la familia 🌙
VITE_SISTER_SECTION_TITLE=Un mensaje de Mia ✨
VITE_SISTER_SECTION_SUBTITLE=
# VITE_SISTER_INTRO_TEMPLATE=Soy {name}, y quiero pintar sonrisas para cuando Max llegue al mundo.
# VITE_SISTER_INTRO_WITHOUT_NAME=Yo también estoy esperando...
# VITE_SISTER_PARAGRAPHS=línea uno\nlínea dos

# ----- Fecha y hora -----
# ISO para cuenta regresiva:
VITE_EVENT_DATE=2026-08-02T15:00:00
# Textos en pantalla (si no los ponés, se infieren):
VITE_EVENT_DATE_LABEL=2 de agosto · 2026
VITE_EVENT_TIME=15:00 hs
VITE_EVENT_ARRIVAL_NOTE=Te esperamos a las 15:00 hs — por favor, llegá puntual 💚
# Tarjeta del evento: tema decorativo (no es la dirección física)
VITE_EVENT_VENUE=Bosque encantado
VITE_EVENT_ADDRESS=

# Alias legacy (mismo significado que EVENT_*):
# VITE_CEREMONY_TITLE=Encuentro en el bosque encantado
# VITE_CEREMONY_DATE=26 de julio, 2026
# VITE_CEREMONY_TIME=16:00 hs
# VITE_CEREMONY_VENUE=Bosque encantado
# VITE_CEREMONY_ADDRESS=...

VITE_EVENT_TITLE=Baby shower · Bosque encantado
VITE_EVENT_INTRO=Un solo encuentro cálido y mágico para darle la bienvenida a Max.
VITE_EVENT_PHYSICAL_LOCATION=Mira Cielos — Ibarbálz 1331, X5004 Córdoba

# ----- Hero -----
VITE_HERO_TITLE=Baby Shower 🌿✨
VITE_HERO_TAGLINE_LEAD=Max está en camino
VITE_HERO_TAGLINE_SOFT=y queremos compartir este momento con la gente que queremos.
VITE_HERO_CELEBRATION=Entre luces, haditas, duendes y un bosque encantado, vamos a juntarnos a celebrar su llegada con una tarde tranquila, rica y llena de amor.
# Legacy (igual que TAGLINE_* si preferís):
# VITE_HERO_BIBLE_REF=
# VITE_HERO_BIBLE_QUOTE=
# VITE_HERO_OUR_YES=

# Carrusel del hero (comma-separadas). Por defecto usa fotos en /public/images/
# Hero: 3 fotos + filtro “bosque” en CSS (.hero-bosque-photo)
VITE_HERO_IMAGES=/images/ecografia-max.png,/images/familia-entera-manos-pintura.png,/images/mama-max-panza.png

# ----- Mensaje familiar (párrafos separados por \\n) -----
# VITE_FAMILY_MESSAGE=...

# ----- Historia / imagen -----
VITE_OUR_STORY_TITLE=Antes del primer hola
# VITE_OUR_STORY_CONTENT=...
VITE_OUR_STORY_IMAGE=/images/familia-revelacion-azul.png

# ----- Agenda (la sección no se muestra en esta invitación; variables solo por si reactivás el componente) -----
# VITE_SCHEDULE=[{"time":"16:00","event":"Bienvenida","icon":"glass"},...]
# VITE_SCHEDULE_SECTION_TITLE=Agenda del encuentro
# VITE_SCHEDULE_SECTION_SUBTITLE=Un ritmo tranquilo para disfrutar sin apuros

# ----- Juegos (sección opcional; por defecto desactivada) -----
VITE_GAMES_SECTION_ENABLED=false
VITE_GAMES_SECTION_TITLE=Juegos y mimos para el día
# VITE_GAMES_ITEMS_JSON=[{"id":"x","title":"","description":"","icon":"calendar"}]

# ----- Galería -----
# VITE_GALLERY_IMAGES=/a.jpg,/b.jpg
# o JSON con alt
VITE_GALLERY_SECTION_TITLE=Brillitos del bosque
VITE_GALLERY_SECTION_SUBTITLE=Lugares mágicos hasta tener las fotos definitivas

# ----- Ubicación -----
VITE_LOCATION_VENUE=Mira Cielos
VITE_LOCATION_ADDRESS=Ibarbálz 1331, General Paz, Córdoba
VITE_LOCATION_SECTION_TITLE=Cómo llegar al bosque
VITE_LOCATION_SECTION_LEAD=El encuentro es en el edificio Mira Cielos — Ibarbálz 1331, General Paz. Usá el mapa para la ruta exacta.
VITE_LOCATION_LAT=-31.407736
VITE_LOCATION_LNG=-64.173544
VITE_LOCATION_DIRECTIONS=Hay estacionamiento. Si necesitás ayuda con el acceso, escribinos por WhatsApp.
VITE_LOCATION_MAP_URL=https://maps.app.goo.gl/pvMM1joTn4KRggTB9
VITE_LOCATION_MAP_EMBED_URL=https://www.google.com/maps?q=MIRACIELOS,+Ibarbalz+1331,+C%C3%B3rdoba&z=16&output=embed

# ----- Regalos -----
VITE_GIFTS_TITLE=Regalos y detalles
VITE_GIFTS_MESSAGE=Tu abrazo ya llena el bosque de alegría, pero cada gesto de amor se agradece de todo corazón 💚
# Wish list Pinterest (u otra URL):
VITE_GIFTS_PALETTE_NOTE=Si elegís envoltorio, tarjetas o detalles decorativos, nos encantarían tonos de esta paleta del bosque (verdes, pasteles y rosas suaves) 💚
VITE_GIFTS_REGISTRY_URL=https://pin.it/81UqKxDXM
VITE_GIFTS_REGISTRY_TITLE=Wish list de Max
VITE_GIFTS_REGISTRY_DESCRIPTION=Ideas de regalos en Pinterest — si querés sumar un detalle, acá van algunas sugerencias 💚
VITE_GIFTS_REGISTRY_BUTTON_LABEL=Ver wish list en Pinterest
# VITE_GIFTS_MERCADO_LIBRE_URL=https://...
VITE_BANK_TRANSFER_ENABLED=true
VITE_BANK_ALIAS=Bebe.Max.Ppay
VITE_BANK_NAME=
VITE_BANK_ACCOUNT=
VITE_BANK_CBU=
VITE_BANK_DESTINATARIO=Yami / Juan

# ----- RSVP (WhatsApp corto + formulario Google obligatorio) -----
VITE_RSVP_ENABLED=true
VITE_RSVP_DEADLINE=2026-07-01
VITE_RSVP_INTRO=Tu respuesta nos ayuda a organizar la merienda.\nAgradecemos que confirmes antes del 1 de julio de 2026.
VITE_RSVP_INLINE_FORM_ENABLED=true
# Campos visibles en pantalla (nombre + cantidad para armar el mensaje de WhatsApp):
VITE_RSVP_FORM_TITLE=Datos para el WhatsApp
VITE_RSVP_FORM_HINT=Sólo estos dos datos van por WhatsApp; el resto está en el formulario.
# Paso WhatsApp (títulos opcionales):
# VITE_RSVP_WHATSAPP_STEP_TITLE=
# VITE_RSVP_WHATSAPP_STEP_HINT=
VITE_RSVP_GOOGLE_FORM_ENABLED=true
VITE_RSVP_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/.../viewform
# Texto del bloque “obligatorio” + etiqueta del botón:
# VITE_RSVP_GOOGLE_STEP_TITLE=
# VITE_RSVP_FORM_MANDATORY_NOTICE=Aunque nos mandes WhatsApp...
# VITE_RSVP_GOOGLE_BUTTON_LABEL=

# VITE_RSVP_QR_IMAGE=/qr-max.png
# VITE_RSVP_QR_CAPTION=Escaneá para abrir el formulario

# ----- Premium (WhatsApp / email) -----
VITE_PREMIUM_FEATURES=true
# Dos números (recomendado): un botón por persona (nombres según VITE_PARENT_MOM_NAME / VITE_PARENT_DAD_NAME)
VITE_RSVP_WHATSAPP_YAMI=
VITE_RSVP_WHATSAPP_JUAN=
# Alternativa legacy: un solo número
# VITE_RSVP_WHATSAPP_ENABLED=true
# VITE_RSVP_WHATSAPP_NUMBER=
# Texto opcional antes del mensaje automático de confirmación:
# VITE_RSVP_WHATSAPP_MESSAGE=Hola...

VITE_RSVP_EMAIL_ENABLED=false
VITE_RSVP_EMAIL_ADDRESS=

# ----- Música / playlist -----
# En la invitación se muestra un botón que abre la lista en Spotify (sin reproductor embebido).
# Preferí pegar aquí la URL normal de la playlist:
VITE_MUSIC_ENABLED=true
VITE_MUSIC_COLLABORATIVE_PLAYLIST_URL=https://open.spotify.com/playlist/TU_PLAYLIST_ID
# Si no cargás COLLABORATIVE, podés usar el embed sólo como respaldo para armar el enlace:
# VITE_MUSIC_SPOTIFY_EMBED=https://open.spotify.com/embed/playlist/37i9dQZF1DX4UtSsGT1Sbe
# Reproductor embebido flotante (opcional): VITE_MUSIC_SPOTIFY_USE_EMBED=true
VITE_MUSIC_AUDIO_URL=
# VITE_MUSIC_PLAYLIST_TITLE=Playlist colaborativa
# VITE_MUSIC_PLAYLIST_DESCRIPTION=Sumá una canción suave entrando a la lista en Spotify...

# ----- Sonido ambiente bosque (opcional, MP3 propio en /public o URL) -----
# VITE_FOREST_AMBIENCE_AUDIO_URL=/audio/bosque-suave.mp3
# VITE_FOREST_AMBIENCE_VOLUME=0.14

# ----- Vestimenta -----
VITE_DRESS_CODE_TITLE=Vestimenta sugerida
VITE_DRESS_CODE_CODE=Fairy woodland · elegance suave
# VITE_DRESS_CODE_DESCRIPTION=...
VITE_DRESS_CODE_COLORS_AVOID=Neón,Rojo chillón fuerte,Contrastes muy duros
VITE_DRESS_CODE_COLORS_SUGGESTED=Salvia · musgo,Lila suave,Crema pergamino,Champagne,Rosa polvo,Dorado apagado

# ----- Redes -----
VITE_SOCIAL_HASHTAG=#BabyShowerMax

# ----- Cuenta atrás / footer -----
VITE_COUNTDOWN_TITLE=Ya casi
VITE_COUNTDOWN_SUBTITLE=Falta poquito para conocerlo ✨
# Pie: foto detrás del cierre (“Te esperamos bajo las estrellas”)
VITE_FOOTER_BACKGROUND_IMAGE=/images/panza-suave.png
# Texto opcional; podés usar «{bebé}» para insertar el nombre desde VITE_COUPLE_NAMES
# VITE_FOOTER_CLOSING=
