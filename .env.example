# ============================================
# CONFIGURACIÓN DE INVITACIÓN DE BODA
# ============================================
# Copia este archivo a .env y edita los valores según tu evento
# Las variables de entorno tienen prioridad sobre los valores en weddingConfig.ts

# ============================================
# INFORMACIÓN DE LOS NOVIOS
# ============================================

VITE_BRIDE_NAME= Novia
VITE_GROOM_NAME=Novio
VITE_COUPLE_NAMES= Novio y Novia
# ============================================
# FECHA Y HORA DEL EVENTO
# ============================================
# Formato: YYYY-MM-DDTHH:mm:ss (ejemplo: 2025-06-15T18:00:00)
VITE_EVENT_DATE=2027-04-22T20:00:00

# ============================================
# IMÁGENES PRINCIPALES (HERO)
# ============================================
# Separa múltiples imágenes con comas (sin espacios)
# Ejemplo: /img1.jpg,/img2.jpg,/img3.jpg,/img4.jpg
# O una sola: /img-principal.jpg
VITE_HERO_IMAGES=/images/1-pareja.jpg,/images/2-pareja.jpg,/images/3-pareja.jpg,/images/4-pareja.jpg



# ============================================
# MÚSICA DE FONDO
# ============================================
# Activar/desactivar música
VITE_MUSIC_ENABLED=true
# Opción 1: URL de Spotify Embed (recomendado)
# Obtén la URL desde: https://open.spotify.com -> Compartir -> Insertar -> Copiar URL
VITE_MUSIC_SPOTIFY_EMBED=https://open.spotify.com/embed/playlist/37i9dQZF1DX4UtSsGT1Sbe
#aca se edita solo la parte de playlist/5KcjoWgB7C261xCaSXYuLH
# Opción 2: URL de audio directo (dejar vacío si usas Spotify)
# Ejemplo: /audio/cancion.mp3 o https://ejemplo.com/audio.mp3

VITE_MUSIC_AUDIO_URL=

# Playlist colaborativa: los invitados pueden sumar temas desde la invitación.
# En Spotify: crear una playlist -> clic derecho -> "Hacer colaborativa" -> Compartir -> Copiar link de la playlist
# Pegar aquí (ej: https://open.spotify.com/playlist/xxxxx). Dejar vacío para ocultar el botón "Sumá tu tema".
VITE_MUSIC_COLLABORATIVE_PLAYLIST_URL=


# ============================================
# UBICACIÓN DEL EVENTO
# ============================================
VITE_LOCATION_VENUE= 
VITE_LOCATION_ADDRESS= Av. Colon 1111
# Coordenadas geográficas (latitud y longitud)
# Encuentra las coordenadas en: https://www.google.com/maps
# Haz clic derecho en el lugar -> "¿Qué hay aquí?" -> Ver coordenadas
VITE_LOCATION_LAT=-31.409044
VITE_LOCATION_LNG=-64.198281
VITE_LOCATION_DIRECTIONS=Con estacionamiento, salon con puerta con rejas.
VITE_LOCATION_MAP_URL=https://maps.app.goo.gl/VbWvtgGn2CwCjDL19

# ============================================
# DETALLES DEL EVENTO (CEREMONIA Y RECEPCIÓN)
# ============================================

#Mesa de Regalos
VITE_GIFTS_TITLE= Mesa de Regalos
VITE_GIFTS_MESSAGE= Si tenes ganas de regalarnos algo, te dejamos algunas opciones: 
VITE_BANK_NAME=Banco macro
VITE_BANK_ACCOUNT= 2345678904567890 (cbu) - A nombre de nombre
VITE_BANK_ALIAS=casamiento.alias

